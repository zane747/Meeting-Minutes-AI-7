OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:9b                # 本地 LLM 模型名稱（Gemma 2 9B）

# === 通用 ===
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100
DATABASE_URL=sqlite+aiosqlite:///./meeting_minutes.db
