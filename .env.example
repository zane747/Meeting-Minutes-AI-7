# === Provider 切換 ===
MODEL_MODE=remote                   # remote / local（預設使用的 Provider）

# === Gemini（遠端模式）===
GEMINI_API_KEY=AIzaSyCQaO2XRZSgUK2E5IXg5dthEJxjdf7_xDg
GEMINI_MODEL=gemini-2.0-flash        # gemini-2.0-flash / gemini-2.5-pro

# === GPU / Device ===
DEVICE=auto                          # auto / cpu / cuda（auto = 有 GPU 就用 GPU）
# 若要啟用 GPU 加速，需安裝 CUDA 版 PyTorch：
#   pip install torch --index-url https://download.pytorch.org/whl/cu121

# === Whisper（本地模式）===
WHISPER_MODEL=medium                 # tiny / base / small / medium / large
# VRAM 不足時的降級順序（從使用者設定的模型開始，依序嘗試更小的模型）
WHISPER_MODEL_FALLBACK_ORDER=medium,small,base,tiny

# === Diarization（說話者辨識，可選）===
DIARIZATION_ENABLED=false              # true / false（是否預設啟用說話者辨識）
HF_TOKEN=                              # HuggingFace access token（pyannote 模型授權需要）
DIARIZATION_DEFAULT_NUM_SPEAKERS=0     # 0 = 自動偵測，>0 = 指定說話者人數

# === Ollama（本地摘要，可選）===
OLLAMA_ENABLED=true                 # true / false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:latest             # gemma2 9B — 摘要品質好，CPU 16 核跑得動
OLLAMA_NUM_CTX=32768                  # Ollama context window 大小（建議 32768 以支援長會議分段摘要合併）
OLLAMA_NUM_THREAD=16                  # CPU 執行緒數（設為你的 CPU 核心數，0 = 自動）
OLLAMA_GPU=auto                       # auto = 自動偵測 GPU | true = 強制 GPU | false = 強制 CPU

# === 通用 ===
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=300
DATABASE_URL=sqlite+aiosqlite:///./meeting_minutes.db
